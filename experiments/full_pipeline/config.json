{
  "comment": "全流程管线配置 — 基于实验对比选出的最佳参数组合",
  "paths": {
    "dom_path": "data/dom3/DOM.tif",
    "dom_world": "data/dom3/DOM.tfw",
    "pointcloud_paths": ["data/pointcloud2/BlockB.ply", "data/pointcloud2/BlockY.ply"],
    "model_path": "models/best.pt",
    "workspace_dir": "experiments/full_pipeline/outputs"
  },
  "slicing": {
    "method": "quadtree_dom",
    "comment_method": "quadtree_dom 不依赖点云，速度快。可选 sahi_dense 获得更全覆盖",
    "cover": {
      "base_tile_size_m": 40,
      "min_tile_size_m": 20,
      "max_tile_size_m": 40,
      "min_edge_density": 0.15,
      "tile_overlap_m": 6.0,
      "skip_empty_tiles": true,
      "black_pixel_threshold": 5,
      "min_content_ratio": 0.35,
      "canny_low": 30,
      "canny_high": 90
    }
  },
  "inference": {
    "imgsz": 1024,
    "conf": 0.4,
    "max_det": 1000,
    "retina_masks": false,
    "min_stone_diameter_m": 1.2,
    "device": 0
  },
  "fusion": {
    "method": "correlation_clustering",
    "comment_method": "实验证明相关性聚类合并率全面优于启发式",
    "correlation": {
      "max_distance_m": 3.0,
      "distance_sigma": 0.80,
      "positive_weight_threshold": 0.55,
      "use_iou": true,
      "iou_weight": 0.3,
      "use_tile_affinity": true,
      "same_tile_boost": 1.50,
      "require_bbox_intersect": true
    }
  },
  "extraction": {
    "voxel_size_m": 0.03,
    "padding_m": 0.5
  },
  "volume": {
    "method": "grid_2d5",
    "comment_method": "2.5D栅格法，最适合航空LiDAR顶面点云。每格柱子求和，底部5%分位估地面",
    "grid_resolution": 0.1
  },
  "stats": {
    "min_diameter_m": 1.2,
    "max_diameter_m": 5.0,
    "diameter_bins": 10,
    "volume_bins": 10
  }
}
